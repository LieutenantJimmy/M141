# ============================================================================
# EVALUIERTE ALTERNATIVE (Aiven) — NICHT PRODUKTIV. Aiven wurde evaluiert, aber
# bewusst zugunsten der eigenen Homelab-Cloud verworfen (volle Kontrolle, kein
# Vendor-Lock, Max-Bonus). Produktive Konfiguration: my_cloud_selfhosted.cnf
# ============================================================================
# ============================================================
# my_aiven.cnf – Produktive Parameter für Aiven for MySQL
# Service: backpacker-aiven-giovanni
# Project: giovanni-m141-lb3
# Autor: Giovanni Merola · M141 LB3 · 30.06.2026
#
# Hinweis: Aiven verwaltet die my.cnf nicht direkt – die unten
# stehenden Schlüssel/Werte werden 1:1 als Service-Advanced-
# Configuration in der Aiven Console gesetzt:
#   Aiven Console → Service "backpacker-aiven-giovanni"
#                 → Advanced configuration → Add configuration option
# Diese Datei dient zur Dokumentation und für lokale Mirror-Setups.
# ============================================================

[mysqld]

# ----- Zeichensatz / Locale -----
character_set_server          = utf8mb4
collation_server              = utf8mb4_unicode_ci
init_connect                  = 'SET NAMES utf8mb4'
default_time_zone             = '+00:00'

# ----- Sicherheit -----
# TLS-Pflicht wird von Aiven auf Service-Ebene erzwungen (nicht abschaltbar),
# zusätzlich erzwingen wir REQUIRE SSL pro User in sql/dcl/03_cloud_users.sql.
local_infile                  = OFF
sql_mode                      = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,ERROR_FOR_DIVISION_BY_ZERO

# ----- Verbindung / Sessions -----
max_connections               = 60      # Plan-abhängig; Hobbyist max ~60
wait_timeout                  = 600
interactive_timeout           = 600
max_allowed_packet            = 16M

# ----- InnoDB -----
default_storage_engine        = InnoDB
innodb_strict_mode            = ON
# innodb_buffer_pool_size wird durch Aiven dynamisch nach Plan gesetzt

# ----- Logging / Audit -----
slow_query_log                = ON
long_query_time               = 1
general_log                   = OFF

# ----- Replikation (nicht zwingend aktiv im Hobbyist Plan) -----
binlog_format                 = ROW
binlog_expire_logs_seconds    = 604800  # 7 Tage
